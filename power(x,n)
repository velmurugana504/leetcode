class Solution {
public:
    double myPow(double x, int n) {
        double res = 1.0;
        long long tmp = n;
        if (tmp < 0) {
            x = 1.0 / x;
            tmp = -tmp;
        }
        while (tmp > 0) {
            if (tmp % 2 == 1) {
                res *= x;
            }
            x *= x;
            tmp /= 2;
        }
        return res;
    }
};
